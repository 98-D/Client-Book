{
  "name": "@clientbook/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf dist",

    "build:main": "tsc -p tsconfig.json",
    "build:preload": "tsc -p tsconfig.preload.json && node scripts/rename-preload.cjs",

    "copy:assets": "node scripts/copy-assets.js",

    "build": "pnpm run clean && pnpm run build:main && pnpm run build:preload && pnpm run copy:assets",

    "typecheck": "tsc -p tsconfig.json --noEmit",

    "start": "electron .",
    "dev": "pnpm run build && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",

    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "pnpm run rebuild:native"
  },
  "dependencies": {
    "@clientbook/contract": "workspace:*",
    "@clientbook/db": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.3"
  }
}